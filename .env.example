# Neon Postgres (pooled connection string recommended for serverless)
DATABASE_URL=

# Optional: copy production DATABASE_URL here to seed / push the live Neon DB from your machine.
#   vercel env pull .env.production.local --environment=production --yes
# Then: npm run db:push:live   (schema)   npm run db:seed:live   (Nanganallur + articles)
# Optional: npm run db:seed:directory   (local directory rows — cites Wikipedia / HRCE / community guides)
# File name is fixed — do not commit it (.gitignore).

# Public site URL for metadata, sitemap, and robots
NEXT_PUBLIC_SITE_URL=https://mynanganallur.in

# Amazon Associates — optional homepage card (use your approved tagged URL from SiteStripe or amzn.to short link)
# NEXT_PUBLIC_AMAZON_AFFILIATE_URL=https://amzn.to/your-tag

# Google Analytics 4 (Measurement ID G-...)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=
# Must match the deployed site URL (include https, no trailing slash)
AUTH_URL=https://mynanganallur.in

# OAuth (optional; configure at least one for sign-in)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: Search Console API — npm run gsc:submit-sitemap
# Enable "Google Search Console API" in Google Cloud; create a service account JSON key.
# Add the service account email in GSC → Settings → Users and permissions (Full).
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json
# Or (CI): paste entire JSON as one line in GSC_SERVICE_ACCOUNT_JSON=
# GSC_SITE_URL=https://mynanganallur.in/
# URL-prefix props need trailing slash. Domain property: sc-domain:mynanganallur.in
# GSC_SITEMAP_URL=https://mynanganallur.in/sitemap.xml
